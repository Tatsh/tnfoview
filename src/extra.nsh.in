!include "FileFunc.nsh"
; From https://github.com/openscad/openscad/blob/master/cmake/nsis/extra-install-commands.nsh.in
!define ARP "Software\Microsoft\Windows\CurrentVersion\Uninstall\@DISPLAY_NAME@"
${GetSize} "$INSTDIR" "/S=0K" $0 $1 $2
IntFmt $0 "0x%08X" $0
WriteRegDWORD SHCTX "${ARP}" "EstimatedSize" "$0"
; Register an "Open with" entry so tnfoview can open .nfo files.
WriteRegStr HKCU "Software\Classes\Applications\tnfoview.exe\shell\open\command" "" '"$INSTDIR\bin\tnfoview.exe" "%1"'
WriteRegStr HKCU "Software\Classes\.nfo\OpenWithProgids" "Applications.tnfoview.exe" ""
